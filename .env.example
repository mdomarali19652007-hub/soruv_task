# ============================================================
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. Service role key and Better Auth
# secret must stay server-side only.
# ============================================================

# --- Better Auth ------------------------------------------------
# Postgres connection string (Supabase "Connection pooling" URL, port 6543).
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:6543/postgres

# 32-byte hex secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL your server is reachable at. Use your deployed domain
# in production (e.g. https://your-app.vercel.app).
BETTER_AUTH_URL=http://localhost:3000

# --- Supabase (server-side) -------------------------------------
SUPABASE_URL=https://xxx.supabase.co
# Service role key bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (client-side, embedded in the bundle) -------------
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Google OAuth (optional) ------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (transactional) --------------------------------------
# Master kill switch. The whole email system (verification + password
# reset) is a no-op unless BOTH of these are set to "true":
#
#   EMAIL_ENABLED=true        (server -- src/server/email.ts)
#   VITE_EMAIL_ENABLED=true   (client -- gates the verification overlay)
#
# When disabled:
#   - signup does not send a verification message
#   - the "verify your email" overlay never appears
#   - password-reset emails silently log at info level (no delivery)
#   - production boot no longer requires RESEND_API_KEY
#
# When enabled, set a provider below. Recommended: Resend
# (https://resend.com). In production, RESEND_API_KEY becomes required.
EMAIL_ENABLED=false
VITE_EMAIL_ENABLED=false
RESEND_API_KEY=
# The visible "From" address. Must be verified in your provider.
EMAIL_FROM=no-reply@localhost

# --- CORS -------------------------------------------------------
# Public site origin (added to the allowlist).
SITE_URL=http://localhost:3000
# Optional comma-separated list of additional allowed origins.
CORS_ALLOWED_ORIGINS=
# On Vercel, the deployment URLs are auto-allowed from the built-in
# VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL / VERCEL_BRANCH_URL env
# vars, including preview URLs matching `<project>-<anything>.vercel.app`.
# You do not need to set these manually; Vercel injects them.
