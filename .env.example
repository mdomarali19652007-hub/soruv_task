# ============================================================
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. Service role key and Better Auth
# secret must stay server-side only.
# ============================================================

# --- Better Auth ------------------------------------------------
# Postgres connection string (Supabase "Connection pooling" URL, port 6543).
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:6543/postgres

# 32-byte hex secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL your server is reachable at. Use your deployed domain
# in production (e.g. https://your-app.vercel.app).
BETTER_AUTH_URL=http://localhost:3000

# --- Supabase (server-side) -------------------------------------
SUPABASE_URL=https://xxx.supabase.co
# Service role key bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (client-side, embedded in the bundle) -------------
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Google OAuth (optional) ------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (transactional) --------------------------------------
# Verification + password-reset messages are sent via Better Auth
# callbacks in src/server/auth.ts. If RESEND_API_KEY is unset, the
# app falls back to logging email bodies to stdout in development;
# in production the server will refuse to boot without a provider.
#
# Recommended: Resend (https://resend.com). Paste the API key here.
RESEND_API_KEY=
# The visible "From" address. Must be verified in your provider.
EMAIL_FROM=no-reply@localhost

# --- CORS -------------------------------------------------------
# Public site origin (added to the allowlist).
SITE_URL=http://localhost:3000
# Optional comma-separated list of additional allowed origins.
CORS_ALLOWED_ORIGINS=
