# ============================================================
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. Service-role keys and Clerk secret
# keys must stay server-side only.
# ============================================================

# --- Clerk ------------------------------------------------------
# Publishable key is safe to embed in the client bundle.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_

# Secret key is SERVER-ONLY -- it can create/ban/delete users.
CLERK_SECRET_KEY=sk_test_

# NOTE: CLERK_WEBHOOK_SECRET does NOT live here. The Clerk webhook
# runs as a Supabase Edge Function (`supabase/functions/clerk-webhook`);
# set the signing secret as a function secret via
# `supabase secrets set CLERK_WEBHOOK_SECRET=whsec_...`.

# Public URL your deployed app is reachable at. Used to build
# referral links (the Supabase Edge Function reads this too).
APP_PUBLIC_URL=http://localhost:3000

# --- Supabase (server-side) -------------------------------------
SUPABASE_URL=https://xxx.supabase.co
# Service role key bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (client-side, embedded in the bundle) -------------
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Image upload (ImgBB) --------------------------------------
# `src/lib/upload-media.ts` uploads task / proof / news / product
# screenshots to ImgBB (free tier). Without this key, callers like
# FolderAView, FolderBView, SocialJobView, LudoEarnView, and the
# admin News & Products forms will throw "ImgBB API Key is missing".
# Get one at https://api.imgbb.com/ (Account -> About).
VITE_IMGBB_API_KEY=

# Storage note: the global profile-pic upload + ad-hoc `uploads/`
# table writes (App.tsx -> `uploadImage()`) use Supabase Storage
# instead. They expect a bucket named `uploads` to exist with
# public read access — create it once via Supabase Studio (Storage
# -> New bucket -> name "uploads", public).

# --- CORS -------------------------------------------------------
# Public site origin (added to the allowlist).
SITE_URL=http://localhost:3000
# Optional comma-separated list of additional allowed origins.
CORS_ALLOWED_ORIGINS=

# --- Admin subdomain (host-based admin routing) -----------------
# When set, the dedicated admin panel is served from this hostname
# (e.g. `admin.example.com`) and `/api/admin/*` rejects requests
# whose Host header does not match. Leave unset to keep using the
# legacy `/admin` path on the apex domain.
ADMIN_HOSTNAME=
# Public origin (https://admin.example.com) of the admin subdomain.
# Added to the CORS allowlist so the admin SPA can call the API.
ADMIN_PUBLIC_URL=
# Same hostname as ADMIN_HOSTNAME but exposed to the client bundle so
# `src/lib/admin-host.ts` can recognise the host at boot. Vite only
# inlines variables prefixed with VITE_.
VITE_ADMIN_HOSTNAME=
# On Vercel, the deployment URLs are auto-allowed from the built-in
# VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL / VERCEL_BRANCH_URL env
# vars, including preview URLs matching `<project>-<anything>.vercel.app`.
# You do not need to set these manually; Vercel injects them.

# --- Image uploads (Supabase Storage) ---------------------------
# Public bucket used by `src/lib/upload-media.ts`. The migration
# `supabase/migrations/20260605_user_uploads_bucket.sql` provisions
# this bucket with public read access. Override only if you renamed
# the bucket in your project.
VITE_SUPABASE_UPLOADS_BUCKET=user-uploads
