# ============================================================
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. Service-role keys and Clerk secret
# keys must stay server-side only.
# ============================================================

# --- Clerk ------------------------------------------------------
# Publishable key is safe to embed in the client bundle.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_

# Secret key is SERVER-ONLY -- it can create/ban/delete users.
CLERK_SECRET_KEY=sk_test_

# Signing secret from the Clerk dashboard -> Webhooks. Used by
# Svix to verify the authenticity of user.created / user.deleted
# webhook payloads hitting /api/webhooks/clerk.
CLERK_WEBHOOK_SECRET=whsec_

# Public URL your server is reachable at. Used to build referral
# links on the server-side webhook (see src/server/webhooks.ts).
APP_PUBLIC_URL=http://localhost:3000

# --- Supabase (server-side) -------------------------------------
SUPABASE_URL=https://xxx.supabase.co
# Service role key bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (client-side, embedded in the bundle) -------------
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- CORS -------------------------------------------------------
# Public site origin (added to the allowlist).
SITE_URL=http://localhost:3000
# Optional comma-separated list of additional allowed origins.
CORS_ALLOWED_ORIGINS=
# On Vercel, the deployment URLs are auto-allowed from the built-in
# VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL / VERCEL_BRANCH_URL env
# vars, including preview URLs matching `<project>-<anything>.vercel.app`.
# You do not need to set these manually; Vercel injects them.
