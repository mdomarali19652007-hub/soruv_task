{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account information and balances.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "number" },
        "referralCode": { "type": "string" },
        "mainBalance": { "type": "number" },
        "totalEarned": { "type": "number" },
        "pendingPayout": { "type": "number" },
        "rank": { "type": "string", "enum": ["Bronze", "Silver", "Gold", "Diamond"] },
        "dailyClaimed": { "type": "boolean" },
        "notifications": { "type": "array", "items": { "type": "object" } },
        "adWatches": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["name", "email", "age"]
    },
    "Withdrawal": {
      "title": "Withdrawal Request",
      "description": "Stores withdrawal requests from users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "date": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "amount", "method", "status", "date"]
    },
    "GmailSubmission": {
      "title": "Gmail Submission",
      "description": "Stores Gmail selling submissions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "date": { "type": "string" },
        "reward": { "type": "number" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "email", "status", "date"]
    },
    "MicrojobSubmission": {
      "title": "Microjob Submission",
      "description": "Stores microjob task submissions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "microjobId": { "type": "string" },
        "link": { "type": "string" },
        "screenshot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "reward": { "type": "number" },
        "date": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "status", "date"]
    },
    "TaskSubmission": {
      "title": "Task Submission",
      "description": "Stores general task submissions (Telegram, FB, etc).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskType": { "type": "string" },
        "userName": { "type": "string" },
        "screenshot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "reward": { "type": "number" },
        "taskId": { "type": "string" },
        "date": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "taskType", "status", "date"]
    },
    "RechargeRequest": {
      "title": "Mobile Recharge Request",
      "description": "Stores mobile recharge requests from users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "phone": { "type": "string" },
        "operator": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["Prepaid", "Postpaid"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "date": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "phone", "operator", "amount", "type", "status", "date"]
    },
    "DriveOffer": {
      "title": "Drive Offer",
      "description": "Stores available drive offers managed by admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "operator": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["title", "operator", "price"]
    },
    "DriveOfferRequest": {
      "title": "Drive Offer Request",
      "description": "Stores drive offer purchase requests from users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "driveOfferId": { "type": "string" },
        "phone": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "date": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "driveOfferId", "phone", "amount", "status", "date"]
    },
    "Product": {
      "title": "E-commerce Product",
      "description": "Stores products available for sale in the e-commerce section.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "image"]
    },
    "ProductOrder": {
      "title": "Product Order",
      "description": "Stores product purchase orders from users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "date": { "type": "string" }
      },
      "required": ["userId", "productId", "address", "phone", "amount", "status", "date"]
    },
    "SmmOrder": {
      "title": "SMM Panel Order",
      "description": "Stores social media marketing service orders.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "service": { "type": "string" },
        "link": { "type": "string" },
        "amount": { "type": "number" },
        "quantity": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "date": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "service", "link", "amount", "quantity", "status", "date"]
    },
    "LudoTournament": {
      "title": "Ludo Tournament",
      "description": "Stores Ludo tournament details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "entryFee": { "type": "number" },
        "prizePool": { "type": "number" },
        "type": { "type": "string" },
        "rules": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "ongoing", "completed", "closed"] },
        "maxPlayers": { "type": "number" },
        "currentPlayers": { "type": "number" },
        "startTime": { "type": "string" },
        "roomCode": { "type": "string" },
        "playerIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "entryFee", "prizePool", "status"]
    },
    "LudoSubmission": {
      "title": "Ludo Submission",
      "description": "Stores Ludo tournament win proof submissions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "ludoUsername": { "type": "string" },
        "tournamentId": { "type": "string" },
        "screenshot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "date": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "tournamentId", "screenshot", "status", "ludoUsername"]
    },
    "Settings": {
      "title": "App Settings",
      "description": "Global application settings controlled by admin.",
      "type": "object",
      "properties": {
        "globalNotice": { "type": "string" },
        "isMaintenance": { "type": "boolean" },
        "minWithdrawal": { "type": "number" },
        "spinCost": { "type": "number" },
        "dailyReward": { "type": "number" },
        "activeFolders": { "type": "array", "items": { "type": "string" } },
        "enabledFeatures": { "type": "array", "items": { "type": "string" } },
        "gmailPassword": { "type": "string" },
        "gmailReward": { "type": "number" },
        "adReward": { "type": "number" },
        "dailyAdLimit": { "type": "number" },
        "totalPaid": { "type": "number" },
        "activeWorkerCount": { "type": "number" },
        "gen1Rate": { "type": "number" },
        "gen2Rate": { "type": "number" },
        "gen3Rate": { "type": "number" }
      }
    },
    "GlobalUpload": {
      "title": "Global Image Upload",
      "description": "Stores all images uploaded globally across the site.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "url": { "type": "string" },
        "context": { "type": "string" },
        "timestamp": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["userId", "url", "timestamp", "date"]
    }
  },
  "firestore": {
    "/uploads/{uploadId}": {
      "schema": "GlobalUpload",
      "description": "Global image uploads for tracking and admin visibility."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Withdrawal requests."
    },
    "/gmailSubmissions/{submissionId}": {
      "schema": "GmailSubmission",
      "description": "Gmail selling submissions."
    },
    "/microjobSubmissions/{submissionId}": {
      "schema": "MicrojobSubmission",
      "description": "Microjob task submissions."
    },
    "/taskSubmissions/{submissionId}": {
      "schema": "TaskSubmission",
      "description": "General task submissions."
    },
    "/rechargeRequests/{requestId}": {
      "schema": "RechargeRequest",
      "description": "Mobile recharge requests."
    },
    "/driveOffers/{offerId}": {
      "schema": "DriveOffer",
      "description": "Available drive offers."
    },
    "/driveOfferRequests/{requestId}": {
      "schema": "DriveOfferRequest",
      "description": "Drive offer purchase requests."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "E-commerce products."
    },
    "/productOrders/{orderId}": {
      "schema": "ProductOrder",
      "description": "User orders for products."
    },
    "/smmOrders/{orderId}": {
      "schema": "SmmOrder",
      "description": "SMM panel service orders."
    },
    "/ludoTournaments/{tournamentId}": {
      "schema": "LudoTournament",
      "description": "Ludo tournament details."
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global app settings."
    }
  }
}
